# SAF account local environment template for agents runtime/invocations.
# Copy to .env in this folder (or export these vars in your shell).

AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# Filled after Terraform apply in SAF account
ATHENA_WORKGROUP=
ATHENA_DATABASE=
CUR_BUCKET=
DATA_BUCKET=
CACHE_TABLE=
MEMORY_ID=

# Keep Slack untouched; can stay empty for now
SLACK_SECRET_ARN=
SLACK_CHANNEL_ID=

MONTHLY_BUDGET=1000
LOG_LEVEL=INFO
