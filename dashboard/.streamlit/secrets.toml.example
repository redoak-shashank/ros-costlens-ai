# ─────────────────────────────────────────────────────────────────────────────
# Streamlit Community Cloud Secrets
#
# Copy this file to secrets.toml and fill in real values.
# On Streamlit Community Cloud, paste these into the app's Secrets settings.
# Docs: https://docs.streamlit.io/deploy/streamlit-community-cloud/deploy-your-app/secrets-management
# ─────────────────────────────────────────────────────────────────────────────

[aws]
# IAM user credentials with read-only access to Cost Explorer, S3, and Lambda.
# Create a dedicated IAM user for the dashboard with least-privilege permissions:
#   - ce:GetCostAndUsage, ce:GetCostForecast, ce:GetDimensionValues
#   - s3:GetObject, s3:ListBucket  (on the dashboard-data bucket)
#   - lambda:InvokeFunction        (on the agent Lambda, for "Ask a Question")
aws_access_key_id = "AKIA..."
aws_secret_access_key = "..."
region = "us-east-1"

[app]
# S3 bucket where the agent reporter writes pre-computed dashboard data.
# This is the bucket created by terraform/modules/dashboard/main.tf.
data_bucket = "agentcore-billing-dev-dashboard-data-123456789012"

# Name of the agent Lambda function (for the "Ask a Question" chat feature).
agent_function_name = "agentcore-billing-dev-slack-handler"

# Monthly budget in USD (used for budget gauge charts).
monthly_budget = 42000
